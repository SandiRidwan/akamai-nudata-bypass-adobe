# WebShare (datacenter proxy — used for read-only scraping)
PROXY_HOST=p.webshare.io:80
PROXY_USER=your_webshare_username
PROXY_PASS=your_webshare_password

# Decodo (residential proxy — required for high-risk actions like registration)
DECODO_PROXY_HOST=gate.decodo.com:10001
DECODO_PROXY_USER=your_decodo_username
DECODO_PROXY_PASS=your_decodo_password

TARGET_URL=https://www.adobe.com
BROWSER_PROFILE=chrome124
